DJANGO_SECRET_KEY=replace-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DARAJA_ENV=sandbox
DARAJA_CALLBACK_BASE_URL=https://your-public-callback-domain.example
DARAJA_TIMEOUT_SECONDS=30
DARAJA_TOKEN_REFRESH_BUFFER_SECONDS=60

DARAJA_SANDBOX_CONSUMER_KEY=your-sandbox-consumer-key
DARAJA_SANDBOX_CONSUMER_SECRET=your-sandbox-consumer-secret
DARAJA_SANDBOX_SHORTCODE=600000
DARAJA_SANDBOX_INITIATOR_NAME=testapi
DARAJA_SANDBOX_INITIATOR_PASSWORD=your-sandbox-initiator-password
DARAJA_SANDBOX_CERTIFICATE_PATH=/home/bob/Documents/GitHub/settlement/security/SandboxCertificate.cer

DARAJA_PRODUCTION_CONSUMER_KEY=your-production-consumer-key
DARAJA_PRODUCTION_CONSUMER_SECRET=your-production-consumer-secret
DARAJA_PRODUCTION_SHORTCODE=your-production-shortcode
DARAJA_PRODUCTION_INITIATOR_NAME=your-production-initiator
DARAJA_PRODUCTION_INITIATOR_PASSWORD=your-production-initiator-password
DARAJA_PRODUCTION_CERTIFICATE_PATH=/home/bob/Documents/GitHub/settlement/security/ProductionCertificate.cer
